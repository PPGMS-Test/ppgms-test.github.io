{
  "name": "ppgms-test-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:homepage": "pnpm --filter github-homepage dev",
    "dev:api": "pnpm --filter paypal-backend-api dev",
    "dev:psp-local": "concurrently -n backend,frontend -c blue,green \"pnpm --filter paypal-backend-api dev\" \"pnpm --filter psp-path-dashboard dev:local\"",
    "build:homepage": "pnpm --filter github-homepage build",
    "build:api": "pnpm --filter paypal-backend-api build"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
