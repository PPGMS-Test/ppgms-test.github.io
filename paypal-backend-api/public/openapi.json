{
  "openapi": "3.0.3",
  "info": {
    "title": "PayPal Backend API",
    "description": "Backend proxy API for PayPal SDK integration. Handles client token generation and order management.",
    "version": "1.0.0"
  },
  "tags": [
    { "name": "Auth", "description": "Client token endpoints" },
    { "name": "Orders", "description": "Order creation and management" },
    { "name": "Orders (BYOK)", "description": "Bring-your-own-key variants. Caller supplies sandbox clientId/clientSecret via HTTP Basic auth; the server forwards them to PayPal REST. No server-side credential storage." },
    { "name": "Apple Pay", "description": "Apple Pay + PayPal integration endpoints" }
  ],
  "paths": {
    "/api/auth/sandbox-client-token": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get sandbox client token",
        "description": "Returns a browser-safe client token for the PayPal sandbox environment (v6-sdk-test app).",
        "responses": {
          "200": {
            "description": "Client token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ClientToken" }
              }
            }
          }
        }
      }
    },
    "/api/auth/live-client-token-avmkf": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get live client token (AVmKF app)",
        "description": "Returns a browser-safe client token for the PayPal live environment (AVmKF app).",
        "responses": {
          "200": {
            "description": "Client token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ClientToken" }
              }
            }
          }
        }
      }
    },
    "/api/apple-pay/config": {
      "get": {
        "tags": ["Apple Pay"],
        "summary": "Get Apple Pay config",
        "description": "Returns the sandbox client ID and environment for Apple Pay SDK initialization. No credentials required.",
        "responses": {
          "200": {
            "description": "Apple Pay config",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "clientId": { "type": "string" },
                    "environment": { "type": "string", "example": "sandbox" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/apple-pay/create-order": {
      "post": {
        "tags": ["Apple Pay"],
        "summary": "Create Apple Pay PayPal order",
        "description": "Creates a PayPal order for Apple Pay checkout. Supports one-time, vault save, and MIT recurring scenarios. Pass credentials via request headers.",
        "parameters": [
          { "name": "x-paypal-client-id", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "x-paypal-client-secret", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "x-paypal-environment", "in": "header", "schema": { "type": "string", "enum": ["sandbox", "production"], "default": "sandbox" } },
          { "name": "x-paypal-auth-assertion", "in": "header", "description": "Required for Partner (3rd-party) mode", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["scenario", "amount"],
                "properties": {
                  "scenario": {
                    "type": "string",
                    "enum": ["one-time-basic", "one-time-vault", "recurring-vault"],
                    "description": "Payment scenario"
                  },
                  "amount": { "type": "string", "example": "10.00" },
                  "currencyCode": { "type": "string", "example": "USD" },
                  "vaultId": { "type": "string", "description": "Required for one-time-vault and recurring-vault scenarios" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Order created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } },
          "400": { "description": "Missing required fields" },
          "500": { "description": "Order creation failed" }
        }
      }
    },
    "/api/apple-pay/capture-order/{orderId}": {
      "post": {
        "tags": ["Apple Pay"],
        "summary": "Capture Apple Pay order",
        "description": "Captures (settles) a PayPal order that was confirmed via Apple Pay. Pass credentials via request headers.",
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" }, "example": "3JR90341RV502671K" },
          { "name": "x-paypal-client-id", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "x-paypal-client-secret", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "x-paypal-environment", "in": "header", "schema": { "type": "string", "enum": ["sandbox", "production"], "default": "sandbox" } },
          { "name": "x-paypal-auth-assertion", "in": "header", "description": "Required for Partner (3rd-party) mode", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Order captured", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } },
          "500": { "description": "Capture failed" }
        }
      }
    },
    "/api/checkout/orders/create": {
      "post": {
        "tags": ["Orders"],
        "summary": "Create order (custom body)",
        "description": "Create a PayPal order with a fully custom order request body.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderRequest" },
              "example": {
                "intent": "CAPTURE",
                "purchaseUnits": [
                  {
                    "amount": {
                      "currencyCode": "USD",
                      "value": "100.00"
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Order created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } }
        }
      }
    },
    "/api/checkout/orders/create-with-sample-data": {
      "post": {
        "tags": ["Orders"],
        "summary": "Create order with sample data",
        "description": "Create a $100 USD sandbox order using built-in sample data. No request body needed.",
        "responses": {
          "200": { "description": "Order created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } }
        }
      }
    },
    "/api/checkout/orders/create-bcdc-inline": {
      "post": {
        "tags": ["Orders"],
        "summary": "Create order (BCDC Inline)",
        "description": "Create a $149.95 order with BCDC Inline payment source and sample shipping data.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "returnUrl": { "type": "string" }
                }
              },
              "example": {
                "returnUrl": "https://example.com/return"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Order created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } }
        }
      }
    },
    "/api/checkout/orders/create-app-switch": {
      "post": {
        "tags": ["Orders"],
        "summary": "Create order (App Switch)",
        "description": "Create a $149.95 order configured for PayPal App Switch flow.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["returnUrl", "cancelUrl"],
                "properties": {
                  "returnUrl": { "type": "string" },
                  "cancelUrl": { "type": "string" }
                }
              },
              "example": {
                "returnUrl": "https://example.com/return",
                "cancelUrl": "https://example.com/cancel"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Order created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } }
        }
      }
    },
    "/api/checkout/orders/{orderId}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order detail",
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "3JR90341RV502671K"
          }
        ],
        "responses": {
          "200": { "description": "Order detail", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } }
        }
      }
    },
    "/api/checkout/orders/{orderId}/capture": {
      "post": {
        "tags": ["Orders"],
        "summary": "Capture order",
        "description": "Capture payment for an approved order.",
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "3JR90341RV502671K"
          }
        ],
        "responses": {
          "200": { "description": "Order captured", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } }
        }
      }
    },
    "/api/byok/auth/client-token": {
      "post": {
        "tags": ["Orders (BYOK)"],
        "summary": "Get browser-safe client token (BYOK)",
        "description": "Issues a PayPal browser-safe client token for the supplied sandbox credentials. Pass clientId/clientSecret via HTTP Basic auth. Used by the JS SDK v6 createInstance() call.",
        "security": [{ "basicAuth": [] }],
        "responses": {
          "200": { "description": "Client token", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClientToken" } } } },
          "401": { "description": "Missing or invalid Authorization: Basic header" }
        }
      }
    },
    "/api/byok/checkout/orders/create-app-switch": {
      "post": {
        "tags": ["Orders (BYOK)"],
        "summary": "Create order (App Switch, BYOK)",
        "description": "Create a $149.95 App-Switch order using caller-supplied sandbox credentials. Pass clientId/clientSecret via HTTP Basic auth.",
        "security": [{ "basicAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["returnUrl", "cancelUrl"],
                "properties": {
                  "returnUrl": { "type": "string" },
                  "cancelUrl": { "type": "string" }
                }
              },
              "example": {
                "returnUrl": "https://example.com/return",
                "cancelUrl": "https://example.com/cancel"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Order created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } },
          "400": { "description": "Missing returnUrl or cancelUrl" },
          "401": { "description": "Missing or invalid Authorization: Basic header" }
        }
      }
    },
    "/api/byok/checkout/orders/{orderId}/capture": {
      "post": {
        "tags": ["Orders (BYOK)"],
        "summary": "Capture order (BYOK)",
        "description": "Capture payment for an approved order using caller-supplied sandbox credentials. Pass clientId/clientSecret via HTTP Basic auth.",
        "security": [{ "basicAuth": [] }],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "3JR90341RV502671K"
          }
        ],
        "responses": {
          "200": { "description": "Order captured", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } },
          "401": { "description": "Missing or invalid Authorization: Basic header" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "PayPal sandbox clientId:clientSecret encoded as base64."
      }
    },
    "schemas": {
      "ClientToken": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "expiresIn": { "type": "integer" },
          "scope": { "type": "string" },
          "tokenType": { "type": "string" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string", "example": "CREATED" },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "href": { "type": "string" },
                "rel": { "type": "string" },
                "method": { "type": "string" }
              }
            }
          }
        }
      },
      "OrderRequest": {
        "type": "object",
        "required": ["intent", "purchaseUnits"],
        "properties": {
          "intent": { "type": "string", "enum": ["CAPTURE", "AUTHORIZE"] },
          "purchaseUnits": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "amount": {
                  "type": "object",
                  "properties": {
                    "currencyCode": { "type": "string", "example": "USD" },
                    "value": { "type": "string", "example": "100.00" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
